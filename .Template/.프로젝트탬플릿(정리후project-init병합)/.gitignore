# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prevent accidental self-clone
/ebest-portal/

# Windows artifacts
nul

# Tool state directories (machine-specific)
.bkit/
.gemini/
.omc/

# 개인 참고용 폴더 (프로젝트별 주석 해제하여 사용)
# .Source-Files/
.Template/
.claude-legacy/

